# ============================================================
# Qoo10 API
# ============================================================
QOO10_SELLER_AUTH_KEY=
QOO10_SAK=
QOO10_USER_ID=
QOO10_DEBUG=1
QOO10_ALLOW_REAL_REG=0      # 1 = 실제 등록 허용 (기본 dry-run)
QOO10_TEST_ITEMCODE=         # 테스트 전용 Qoo10 아이템 코드

# ============================================================
# Google Sheets
# ============================================================
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB_NAME=coupang_datas
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./backend/keys/google-service-account.json

# ============================================================
# Coupang 수집
# ============================================================
# Playwright 로그인 자격증명 (선택 — 없으면 비로그인 수집 시도)
COUPANG_ID=                  # 쿠팡 로그인 ID (이메일 또는 휴대폰번호)
COUPANG_PW=                  # 쿠팡 비밀번호

# 기존 HTTP 수집 방식 쿠키 (Playwright 방식 사용 시 불필요)
COUPANG_COOKIE=

# 디버그 플래그
COUPANG_TRACER=0             # 1 = 상세 로그
PLAYWRIGHT_HEADLESS=1        # 0 = 브라우저 창 표시 (디버그용)
COUPANG_SCRAPE_DRY_RUN=1    # 1 = 시트 write 없이 payload만 출력

# yam yam 쿠키 만료
COOKIE_TTL_DAYS=14

# ============================================================
# 이메일 알림 (쿠키 만료 경고)
# ============================================================
GMAIL_USER=
GMAIL_APP_PASSWORD=          # Google 앱 비밀번호 (계정 → 보안 → 앱 비밀번호)
NOTIFY_EMAIL=

# ============================================================
# 백엔드 API 서버
# ============================================================
BACKEND_PORT=4000
OPENROUTER_API_KEY=

# ============================================================
# OpenClaw 쿠키 자동 갱신
# ============================================================
# Next.js 대시보드 URL (OpenClaw 프록시 엔드포인트 경유)
DASHBOARD_URL=http://localhost:3001
# 백엔드 쿠키 수신 엔드포인트 (OpenClaw가 POST할 주소)
BACKEND_COOKIE_URL=http://localhost:4000/api/cookie/coupang