{
  "name": "qoo10-debug-project",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "qoo10:env": "node scripts/qoo10-env-check.js",
    "qoo10:test:lookup": "npm run qoo10:env && node scripts/qoo10-test-lookup.js",
    "qoo10:register:sample": "node scripts/qoo10-register-cli.js backend/qoo10/sample-newgoods.json",
    "qoo10:register:with-options": "node scripts/qoo10-register-cli.js backend/qoo10/sample-with-options.json",
    "qoo10:register:with-extraimages": "node scripts/qoo10-register-cli.js backend/qoo10/sample-with-extraimages.json",
    "qoo10:register:with-extraimages-options": "node scripts/qoo10-register-cli.js backend/qoo10/sample-with-extraimages-options.json",
    "// Qoo10등록 | 상품등록": "→ npm run qoo10:auto-register",
    "qoo10:auto-register": "node scripts/qoo10-auto-register.js",
    "qoo10:auto-register:dry": "node scripts/qoo10-auto-register.js --dry-run",
    "qoo10:sync:japan-categories": "node scripts/qoo10-sync-japan-categories.js",
    "categories:sync:csv": "node backend/scripts/sync-japan-categories-from-csv.js",
    "categories:sync:csv:dry": "node backend/scripts/sync-japan-categories-from-csv.js --dry-run",
    "japan-categories:sync:csv": "node backend/scripts/sync-japan-categories-from-csv.js",
    "japan-categories:sync:csv:dry": "node backend/scripts/sync-japan-categories-from-csv.js --dry-run",
    "backend:start": "node backend/server.js",
    "sheets:setup": "node backend/scripts/setup-sheets.js",
    "sheets:setup:force": "node backend/scripts/setup-sheets.js --force-defaults",
    "sheets:migrate": "node backend/scripts/migrate-coupang-datas-schema.js",
    "sheets:migrate:dry": "node backend/scripts/migrate-coupang-datas-schema.js --dry-run",
    "// 키워드탐색 | 상품탐색": "→ npm run coupang:discover",
    "coupang:discover": "node backend/scripts/coupang-keyword-discover.js",
    "coupang:discover:dry": "node backend/scripts/coupang-keyword-discover.js --dry-run",
    "coupang:browser:start": "node backend/scripts/coupang-browser-start.js",
    "coupang:browser:stop": "node backend/scripts/coupang-browser-stop.js",
    "coupang:browser:status": "node backend/scripts/coupang-browser-status.js",
    "// 상품수집 | 수집": "→ npm run coupang:collect",
    "coupang:collect": "node backend/scripts/coupang-collect-discovered.js",
    "coupang:collect:dry": "node backend/scripts/coupang-collect-discovered.js --dry-run",
    "coupang:collect:one": "node backend/scripts/coupang-collect-one.js",
    "// 등록대기열 | 프로모트": "→ npm run coupang:promote",
    "coupang:promote": "node backend/scripts/coupang-promote-to-pending.js",
    "coupang:promote:dry": "node backend/scripts/coupang-promote-to-pending.js --dry-run",
    "// 상품승인 | 승인": "→ npm run coupang:approve",
    "coupang:approve": "node backend/scripts/coupang-approve-pending.js",
    "coupang:approve:dry": "node backend/scripts/coupang-approve-pending.js --dry-run",
    "// 재고확인 | 재고체크": "→ npm run stock:check",
    "stock:check": "node backend/scripts/coupang-stock-monitor.js",
    "stock:check:dry": "node backend/scripts/coupang-stock-monitor.js --dry-run",
    "stock:check:test": "node backend/scripts/coupang-stock-monitor.js --dry-run --limit=3",
    "email:test": "node backend/scripts/test-email-alert.js",
    "coupang:collect:resume": "node backend/scripts/coupang-collect-discovered.js",
    "// 쿠키갱신": "→ npm run cookie:refresh",
    "cookie:refresh": "node backend/scripts/coupang-cookie-refresh.js",
    "cookie:refresh:force": "node backend/scripts/coupang-cookie-refresh.js --force",
    "groups:detect": "node backend/scripts/detect-groups.js",
    "groups:detect:dry": "node backend/scripts/detect-groups.js --dry-run",
    "qoo10:goods:suspend": "node backend/scripts/qoo10-goods-status.js --status=1",
    "qoo10:goods:resume": "node backend/scripts/qoo10-goods-status.js --status=2",
    "qoo10:goods:discontinue": "node backend/scripts/qoo10-goods-status.js --status=3",
    "migrate:multi-option": "node backend/scripts/migrate-to-multi-option.js",
    "migrate:multi-option:dry": "node backend/scripts/migrate-to-multi-option.js --dry-run",
    "qoo10:inventory:delete-unit": "node backend/scripts/qoo10-delete-inventory-unit.js",
    "sheets:reset": "node backend/scripts/reset-coupang-datas.js",
    "sheets:reset:dry": "node backend/scripts/reset-coupang-datas.js --dry-run",
    "qoo10:import:existing": "node scripts/qoo10-import-existing-goods.js",
    "qoo10:import:existing:dry": "node scripts/qoo10-import-existing-goods.js --dry-run",
    "qoo10:translate:titles": "node scripts/qoo10-translate-titles.js",
    "qoo10:translate:titles:dry": "node scripts/qoo10-translate-titles.js --dry-run",
    "// 주문확인": "→ npm run qoo10:order:sync",
    "qoo10:order:sync": "node backend/scripts/qoo10-order-sync.js",
    "qoo10:order:sync:dry": "node backend/scripts/qoo10-order-sync.js --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "nodemailer": "^8.0.2",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
