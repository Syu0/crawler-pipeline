  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "nodemailer": "^8.0.2",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
