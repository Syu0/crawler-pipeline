{
  "name": "qoo10-debug-project",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "qoo10:env": "node scripts/qoo10-env-check.js",
    "qoo10:test:lookup": "npm run qoo10:env && node scripts/qoo10-test-lookup.js",
    "qoo10:register:sample": "node scripts/qoo10-register-cli.js backend/qoo10/sample-newgoods.json",
    "qoo10:register:with-options": "node scripts/qoo10-register-cli.js backend/qoo10/sample-with-options.json",
    "qoo10:register:with-extraimages": "node scripts/qoo10-register-cli.js backend/qoo10/sample-with-extraimages.json",
